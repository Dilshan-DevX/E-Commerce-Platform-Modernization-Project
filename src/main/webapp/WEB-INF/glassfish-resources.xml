        name="TechMartPool" 
        res-type="javax.sql.DataSource" 
        datasource-classname="com.mysql.cj.jdbc.MysqlDataSource" 
        pool-resize-quantity="2" 
        max-pool-size="50" 
        steady-pool-size="8">
        
        <property name="serverName" value="127.0.0.1"/>
        <property name="portNumber" value="3306"/>
        <property name="databaseName" value="emart_db"/>
        <property name="User" value="root"/>
        <property name="Password" value="Dilshan@2003"/>
        <property name="URL" value="jdbc:mysql://127.0.0.1:3306/emart_db?useSSL=false&amp;allowPublicKeyRetrieval=true"/>
    </jdbc-connection-pool>

    <jdbc-resource 
        pool-name="TechMartPool" 
        jndi-name="jdbc/TechMartDS"/>
